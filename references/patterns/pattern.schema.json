{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "html-ppt pattern metadata",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "title",
    "htmlDemo",
    "summary",
    "tags",
    "themeHints",
    "flexible",
    "legacy",
    "layout",
    "themeStrategy",
    "defaults",
    "constraints"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "htmlDemo": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "aliases": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "themeHints": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "flexible": { "type": "boolean" },
    "legacy": { "type": "boolean" },
    "layout": {
      "type": "object",
      "required": ["type", "orientation", "minItems", "maxItems"],
      "properties": {
        "type": { "type": "string" },
        "orientation": { "type": "string" },
        "minItems": { "type": "integer", "minimum": 1 },
        "maxItems": { "type": "integer", "minimum": 1 },
        "supportsInsightBar": { "type": "boolean" },
        "notes": { "type": "string" }
      },
      "additionalProperties": true
    },
    "slots": {
      "type": "array",
      "items": { "type": "string" }
    },
    "themeStrategy": {
      "type": "object",
      "required": ["mode", "tokens"],
      "properties": {
        "mode": { "type": "string", "enum": ["theme-tokens"] },
        "tokens": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "type": "string" }
        },
        "overrides": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        }
      },
      "additionalProperties": true
    },
    "defaults": {
      "type": "object",
      "required": ["contentDensity", "componentScale"],
      "properties": {
        "contentDensity": { "type": "string" },
        "componentScale": { "type": "string" }
      },
      "additionalProperties": true
    },
    "constraints": {
      "type": "object",
      "required": ["minContrastBody", "minContrastLarge"],
      "properties": {
        "minContrastBody": { "type": "number", "minimum": 1 },
        "minContrastLarge": { "type": "number", "minimum": 1 }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
